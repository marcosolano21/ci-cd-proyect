pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo '========== CHECKOUT =========='
                git url: 'https://github.com/marcosolano21/ci-cd-project-docker-jenkins-ec2.git', branch: 'main'
            }
            post {
                success {
                    echo 'Checkout completed successfully.'
                }

                failure {
                    echo 'Checkout failed.'
                }
            }
        }

        stage('Build') {
            steps {
                echo '========== BUILD =========='
                sh 'docker compose build'
            }
            post {
                success {
                    echo 'Build completed successfully.'
                }

                failure {
                    echo 'Build failed.'
                }
            }            
        }

        stage('Start Containers') {
            steps {
                echo '========== START CONTAINERS =========='
                sh 'docker compose up -d'
            }
            post {
                success {
                    echo 'Start Containers completed successfully.'
                }

                failure {
                    echo 'Start Containers failed.'
                }
            }            
        }

        stage('Health Check') {
            steps {
                echo '========== HEALTH CHECK =========='
                sh 'docker exec nginx curl -f http://localhost'
            }
            post {
                success {
                    echo 'Health Check completed successfully.'
                }

                failure {
                    echo 'Health Check failed.'
                }
            }            
        }

        stage('Functional Test') {
            steps {
                echo '========== FUNCTIONAL TEST =========='
                sh '''
                    docker exec nginx curl -f http://localhost > output.html
                    grep "System Monitor" output.html
                '''
            }
            post {
                success {
                    echo 'Functional Test completed successfully.'
                }

                failure {
                    echo 'Functional Test failed.'
                }
            }            
        }
        
        stage('Deploy') {
            steps {
                sshagent(credentials: ['ec2-ssh-key']) { // This is the Key name you need to configure to SSH to the EC2 instance
                    sh '''
                        ssh -o StrictHostKeyChecking=no ubuntu@34.207.198.223 " 
                            cd /home/ubuntu/ci-cd-proyect/ &&
                            git pull &&
                            docker compose down &&
                            docker compose up -d --build
                        "
                    ''' // Here you need to change the Public IP of your EC2 instance
                }
            }
        }
        
        stage('Verify Deployment') {
            steps {
                sh 'curl -f http://34.207.198.223' // Here you need to change the Public IP of your EC2 instance
            }
        }
        
        
    }

    post {

        success {
            echo 'Pipeline completed successfully.'
        }

        failure {
            echo 'Pipeline failed. Check the logs above for the failed stage.'
        }

        always {
            echo 'Cleaning up containers...'
            sh 'docker compose down'
            echo 'Cleanup completed.'
        }
    }
}