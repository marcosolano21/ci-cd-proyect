pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo '========== CHECKOUT =========='
                git url: 'https://github.com/marcosolano21/ci-cd-project-docker-jenkins-ec2.git', branch: 'jenkis-dockerhub-ansible'
            }
            post {
                success {
                    echo 'Checkout completed successfully.'
                }

                failure {
                    echo 'Checkout failed.'
                }
            }
        }

        stage('Build') {
            steps {
                echo '========== BUILD =========='
                //sh 'docker compose build'
                sh '''
                    docker build -t marcosolano/flask:latest \
                        -t marcosolano/flask:${BUILD_NUMBER} \
                        ./flask

                    docker build -t marcosolano/nginx:latest \
                        -t marcosolano/nginx:${BUILD_NUMBER} \
                        ./nginx
                '''
            }
            post {
                success {
                    echo 'Build completed successfully.'
                }

                failure {
                    echo 'Build failed.'
                }
            }            
        }

        stage('Start Containers') {
            steps {
                echo '========== START CONTAINERS =========='
                sh 'docker compose up -d'
            }
            post {
                success {
                    echo 'Start Containers completed successfully.'
                }

                failure {
                    echo 'Start Containers failed.'
                }
            }            
        }

        stage('Health Check') {
            steps {
                echo '========== HEALTH CHECK =========='
                sh 'docker exec nginx curl -f http://localhost'
            }
            post {
                success {
                    echo 'Health Check completed successfully.'
                }

                failure {
                    echo 'Health Check failed.'
                }
            }            
        }

        stage('Functional Test') {
            steps {
                echo '========== FUNCTIONAL TEST =========='
                sh '''
                    docker exec nginx curl -f http://localhost > output.html
                    grep "System Monitor" output.html
                '''
            }
            post {
                success {
                    echo 'Functional Test completed successfully.'
                }

                failure {
                    echo 'Functional Test failed.'
                }
            }            
        }
        // Docker login
        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login \
                        -u "$DOCKER_USER" \
                        --password-stdin
                    '''
                }
            }
        }
        //
        
        // Push images
        stage('Push Images') {
            steps {
                sh '''
                    docker push marcosolano/flask:latest
                    docker push marcosolano/flask:${BUILD_NUMBER}
        
                    docker push marcosolano/nginx:latest
                    docker push marcosolano/nginx:${BUILD_NUMBER}
                '''
            }
        }
        ///
        
        stage('Deploy') {
            steps {
                sshagent(credentials: ['ec2-ssh-key']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no ubuntu@34.207.198.223 "
                            cd /home/ubuntu/ci-cd-proyect/ &&
                            git pull &&
                            docker compose down &&
                            docker compose up -d --build
                        "
                    '''
                }
            }
        }
        
        stage('Verify Deployment') {
            steps {
                sh 'curl -f http://34.207.198.223'
            }
        }
        
        
    }

    post {

        success {
            echo 'Pipeline completed successfully.'
        }

        failure {
            echo 'Pipeline failed. Check the logs above for the failed stage.'
        }

        always {
            echo 'Cleaning up containers...'
            sh 'docker compose down'
            echo 'Cleanup completed.'
        }
    }
}