pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/marcosolano21/ci-cd-proyect.git', branch: 'main'
            }
        }

        stage('Build') {
            steps {
                sh 'docker compose build'
            }
        }

        stage('Start Containers') {
            steps {
                sh 'docker compose up -d'
            }
        }

        stage('Health Check') {
            steps {
                sh 'curl http://localhost'
            }
        }

        stage('Functional Test') {
            steps {
                sh '''
                    curl http://localhost > output.html
                    grep "System Dashboard" output.html
                '''
            }
        }
    }

    post {
        always {
            sh 'docker compose down'
        }
    }
}